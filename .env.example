# Deploy config. Copy this to .env and fill in your own values:  cp .env.example .env
# .env is gitignored and must never be committed.
#
# Anything already set in your environment wins over .env, so you can override per run:
#   VPS=root@1.2.3.4 SSH_KEY=~/.ssh/key bash deploy.sh

# The server to deploy to, as user@host. The host can be an IP or a DNS name.
VPS=root@YOUR_SERVER

# Path to the SSH private key for that host.
SSH_KEY=$HOME/.ssh/your_deploy_key

# Hostname your dashboard will be served on. deploy.sh checks your Caddyfile for this block
# and prints the finished URL.
STATS_HOST=stats.example.com

# Login name seeded on a fresh install. You add and remove users later from the Settings page.
AUTH_USER=admin
