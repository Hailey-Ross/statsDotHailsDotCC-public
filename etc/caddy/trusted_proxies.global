# Reference fragment for /etc/caddy/Caddyfile: the GLOBAL options block (must be the very first
# block in the Caddyfile, before the (access_log) snippet and all site blocks).
# It makes Caddy trust Cloudflare and read the real visitor IP from Cf-Connecting-Ip, so the access
# log records real client IPs for the proxied sites (GoAccess maps %h -> client_ip).
# The IP ranges are Cloudflare's published set (cloudflare.com/ips-v4 + ips-v6); refresh if they change.

{
	servers {
		client_ip_headers Cf-Connecting-Ip
		trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
	}
}
