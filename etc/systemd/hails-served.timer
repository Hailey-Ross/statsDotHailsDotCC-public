[Unit]
Description=Refresh the requests served counter

[Timer]
# Every 6 hours from midnight UTC. UTC is stated explicitly so the schedule does not drift if the
# box timezone changes.
OnCalendar=*-*-* 00,06,12,18:00:00 UTC
# Catch up on the next boot if the machine was down for a firing, otherwise the counter could sit
# stale until the next one.
Persistent=true

[Install]
WantedBy=timers.target
