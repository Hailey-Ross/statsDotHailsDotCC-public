# Machine specific settings for the stats pipeline.
#
# deploy.sh copies this to /etc/hails-stats/config.env the first time and never touches it again,
# so your edits are safe across redeploys. Every systemd unit reads it, so after changing anything
# here run:  systemctl restart hails-perf && systemctl start hails-stats.service
#
# Everything has a working default. You can leave the whole file alone and the dashboard still
# comes up, you just will not get service uptime or a public network map.

# ---- Performance page: what to chart ------------------------------------------------------------

# Hardware is discovered when the collector starts, so you normally set none of this. Every disk,
# filesystem and physical interface found gets its own card on the page, and each keeps its own
# history, so adding hardware later does not disturb what is already recorded.
#
# These two only exist to pin the list by hand if discovery ever picks wrong. Comma separated.
#HAILS_PERF_DISK=vda,vdb
#HAILS_PERF_NIC=eth0

# How often to sample /proc, in seconds. 10 gives you a genuinely useful 1 minute average. Raising
# it saves a trivial amount of CPU and costs you resolution.
#HAILS_PERF_INTERVAL=10

# ---- Performance page: what to watch ------------------------------------------------------------

# Local systemd units to report, comma separated. The .service suffix is added if you leave it off.
# These give you exact restart times and per service memory for free.
HAILS_PERF_UNITS=caddy.service,docker.service

# Sites to probe over the network, so you get real availability and latency rather than just
# "the process is running". Format is name|url|healthy status codes, separated by semicolons.
#
# The status codes matter more than they look. Plenty of healthy sites answer a redirect or an auth
# challenge on their root, and if you only accept 200 they will show as down forever. Check what
# yours actually returns first:  curl -o /dev/null -w '%{http_code}\n' https://your.site/
#
# Empty by default, so a fresh install never fires requests at hosts it was not told about.
#HAILS_PERF_TARGETS=site|https://example.com/|200 ; shortener|https://l.example.com/|200,301 ; dashboard|https://stats.example.com/|401

# How often to probe those sites, in seconds. 300 is a good balance. Going much lower means real
# traffic to your own sites all day, and it is the first thing to raise if the collector ever costs
# more CPU than you would like.
#HAILS_PERF_HTTP=300

# How often to read systemd and docker state, in seconds. These barely change, so 300 is plenty.
# Note this is why a container you just restarted can take up to 5 minutes to update on the page.
#HAILS_PERF_LOCAL=300

# ---- Network map --------------------------------------------------------------------------------

# Name shown on the map and in its page titles.
HAILS_MAP_ORG=example

# Friendly labels for the localhost ports your Caddyfile proxies to, so the map reads as
# "link shortener" instead of "127.0.0.1:3000". Format is port|label, comma separated.
#HAILS_MAP_PORTSVC=3000|Link shortener,8002|Radio,9080|Links page

# The map always writes a private copy to /srv/stats/map.html behind your dashboard login.
#
# Set this to ALSO publish a sanitized public version into that host's static root, as
# network.html. The public version drops ports, localhost upstreams, filesystem paths and any host
# behind auth. Leave it unset and no public page is produced at all, which is the safe default.
#HAILS_MAP_PUBLIC_HOST=example.com
#HAILS_MAP_CANON=https://example.com/network.html

# ---- Requests served counter --------------------------------------------------------------------

# hails-served.py totals every request in the bandwidth rollup and writes served.js into this
# directory, holding the sentence "Over N requests served". A public page can load that file and
# show the figure. Refreshed every 6 hours from 00:00 UTC by hails-served.timer.
#
# Point it at a directory your web server already serves. If you run several sites, use a shared
# asset host so they all read the same file and stay in step.
#
# Leave it unset and nothing is written at all, which is the safe default.
#HAILS_SERVED_ROOT=/srv/assets.example.com

# Head start added to the live count, for traffic served before the rollup existed. Zero by default,
# so the figure on the page is the real one.
#HAILS_SERVED_BASELINE=0

# ---- Storage --------------------------------------------------------------------------------

# Where the durable history lives: the bandwidth rollup and the performance rings. This sits outside
# /srv/stats on purpose, because that directory is wiped and rebuilt every 5 minutes.
#HAILS_PERF_DIR=/var/lib/hails-stats
#HAILS_ROLLUP=/var/lib/hails-stats/bandwidth.json
